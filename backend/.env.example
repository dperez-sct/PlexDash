DATABASE_URL=postgresql://plexdash:plexdash@localhost:5432/plexdash
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here
DEBUG=true

# Security settings (recommended to configure in production)
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# Set to true if serving over HTTPS (enables secure cookies)
HTTPS_ONLY=false

# Comma-separated list of allowed origins for CORS. Use * only for local dev.
# Example: ALLOWED_ORIGINS=https://plexdash.yourdomain.com
ALLOWED_ORIGINS=*
